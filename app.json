{
  "expo": {
    "name": "PekalonganPay",
    "slug": "pekalongan-pay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pekalonganpay",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pekalonganpay.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "PekalonganPay menggunakan Face ID untuk mengamankan transaksi Anda",
        "NSLocationWhenInUseUsageDescription": "PekalonganPay memerlukan akses lokasi untuk menemukan UMKM dan masjid terdekat",
        "NSContactsUsageDescription": "PekalonganPay memerlukan akses kontak untuk memudahkan transfer"
      }
    },
    "android": {
      "package": "com.pekalonganpay.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_CONTACTS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A1628",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "PekalonganPay uses Face ID to secure your transactions"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "PekalonganPay needs your location to find nearby merchants and mosques"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "PekalonganPay uses your contacts to make transfers easier"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
